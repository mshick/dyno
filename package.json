{
  "name": "@mshick/dyno",
  "version": "0.1.0",
  "description": "A simple DynamoDB client.",
  "keywords": [
    "dynamodb",
    "aws",
    "client",
    "dyno"
  ],
  "homepage": "https://github.com/mshick/dyno#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mshick/dyno.git"
  },
  "bugs": {
    "url": "https://github.com/mshick/dyno/issues"
  },
  "license": "MIT",
  "author": "Michael Shick <m@shick.us>",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "prebuild": "pnpm clean",
    "clean": "rm -rf dist *.tsbuildinfo",
    "check": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "3.848.0",
    "@aws-sdk/lib-dynamodb": "3.848.0",
    "@aws-sdk/util-dynamodb": "3.848.0",
    "@smithy/node-http-handler": "4.4.5",
    "@smithy/service-error-classification": "4.2.5",
    "@smithy/util-retry": "4.2.5",
    "big.js": "6.2.2",
    "debug": "4.4.1",
    "fastq": "1.17.1",
    "lodash": "4.17.21"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@faker-js/faker": "9.6.0",
    "@smithy/types": "4.9.0",
    "@tsconfig/node24": "^24.0.0",
    "@types/big.js": "6.2.2",
    "@types/debug": "4.1.12",
    "@types/lodash": "4.17.20",
    "@types/node": "^24.0.0",
    "@vitest/coverage-istanbul": "^4.1.5",
    "docker-compose": "^1.2.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-tsconfig-paths": "^5.0.0",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@10.19.0",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10 <11"
  },
  "pnpm": {
    "overrides": {
      "@smithy/types": "4.9.0"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}